{
  "name": "nine",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "EXPO_PUBLIC_BUILD_ID=$(git rev-parse --short HEAD)-$(date +%y%m%d.%H%M) expo export --platform web && pnpm exec workbox generateSW workbox-config.js",
    "deploy": "pnpm run build:web && pnpm dlx eas-cli@latest deploy",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "check-env": "node scripts/check-env.js",
    "check": "eslint . && prettier --check . && tsc --noEmit && knip && vitest run",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:status": "supabase status"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.33",
    "@supabase/supabase-js": "^2.110.8",
    "@t3-oss/env-core": "^0.13.11",
    "@xstate/react": "^6.1.0",
    "clsx": "^2.1.1",
    "expo": "55.0.9",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.36",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-linear-gradient": "~55.0.16",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.11",
    "expo-updates": "~55.0.25",
    "narrowland": "^1.9.0",
    "nativewind": "5.0.0-preview.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-css": "^3.0.6",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-url-polyfill": "^4.0.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.2",
    "tailwind-merge": "^3.6.0",
    "xstate": "^5.30.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "^55.0.13",
    "eslint": "^10.1.0",
    "eslint-plugin-sonarjs": "^4.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "knip": "^6.27.0",
    "postcss": "^8.5.8",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "workbox-cli": "^7.4.1"
  },
  "private": true,
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1",
      "shell-quote": "^1.8.4",
      "@xmldom/xmldom": "^0.8.13",
      "tmp": "^0.2.6",
      "ws@>=8.0.0 <8.21.0": "^8.21.0",
      "ws@>=7.0.0 <7.5.11": "^7.5.11",
      "brace-expansion@<1.1.16": "^1.1.16",
      "brace-expansion@>=3.0.0 <5.0.7": "^5.0.7",
      "js-yaml@>=4.0.0 <4.3.0": "^4.3.0",
      "js-yaml@>=3.0.0 <3.15.0": "^3.15.0",
      "fast-uri@>=3.0.0 <=3.1.3": "^3.1.4"
    },
    "patchedDependencies": {
      "@expo/router-server@55.0.18": "patches/@expo__router-server@55.0.18.patch"
    }
  }
}
